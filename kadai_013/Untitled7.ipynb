      "source": [
        "def calculate_tax_price(price, tax_rate):\n",
        "  total_price = price + (price * tax_rate / 100)\n",
        "  return total_price\n",
        "\n",
        "item_price = 110\n",
        "tax_percent = 10\n",
        "\n",
        "result = calculate_tax_price(item_price, tax_percent)\n",
        "\n",
        "print(result)"
      ]
